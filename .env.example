# Meta / Facebook App credentials
META_APP_ID=1414848844000934
META_APP_SECRET=your_app_secret_here

# Graph API version
META_GRAPH_VERSION=v21.0

# Session cookie encryption secret (min 32 chars) - generate with: openssl rand -base64 32
SESSION_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# Public base URL (used for the OAuth redirect URI).
# Leave empty to auto-detect from the request host (works on localhost and Vercel).
# Set explicitly in production if you use a custom domain, e.g. https://socialflow.vercel.app
NEXT_PUBLIC_BASE_URL=
